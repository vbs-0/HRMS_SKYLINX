generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String                  @id @default(cuid())
  name               String
  legalName          String
  logoUrl            String?
  address            String?
  taxId              String?
  workWeek           String                  @default("Monday to Saturday")
  timezone           String                  @default("Asia/Kolkata")
  status             String                  @default("ACTIVE")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  announcements      Announcement[]
  appraisals         Appraisal[]
  appraisalCycles    AppraisalCycle[]
  appraisalTemplates AppraisalTemplate[]
  tenantAudits       AuditLog[]              @relation("TenantAuditLogs")
  clientRules        ClientRule[]
  assets             CompanyAsset[]
  policies           CompanyPolicy[]
  compensationCycles CompensationCycle[]
  customFieldDefs    CustomFieldDefinition[]
  departments        Department[]
  employees          Employee[]
  employeeGrades     EmployeeGrade[]
  employmentTypes    EmploymentType[]
  holidays           Holiday[]
  jobRequisitions    JobRequisition[]
  leaveBlockLists    LeaveBlockList[]
  leavePolicies      LeavePolicy[]
  locations          Location[]
  settings           ModuleSetting[]
  payrollRuns        PayrollRun[]
  reminderRules      ReminderRule[]
  retentionBonuses   RetentionBonus[]
  tenantRoles        Role[]                  @relation("TenantRoles")
  salaryWithholdings SalaryWithholding[]
  salaryStructureTemplates SalaryStructureTemplate[]
  subscription       Subscription?
  surveys            Survey[]
  tickets            Ticket[]
  tenantUsers        User[]                  @relation("TenantUsers")
  payrollComponentConfigs PayrollComponentConfig[]
  penaltyLogs        PenaltyLog[]
}

model User {
  id             String          @id @default(cuid())
  employeeId     String?         @unique
  email          String          @unique
  phone          String?         @unique
  passwordHash   String
  status         UserStatus      @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenantId       String?
  auditLogs      AuditLog[]      @relation("AuditActor")
  notifications  Notification[]
  otpTokens      OtpToken[]
  socialComments SocialComment[]
  socialLikes    SocialLike[]
  socialPosts    SocialPost[]
  ticketComments TicketComment[]
  employee       Employee?       @relation(fields: [employeeId], references: [id])
  tenant         Company?        @relation("TenantUsers", fields: [tenantId], references: [id], onDelete: Cascade)
  roles          UserRole[]
}

model Role {
  id           String           @id @default(cuid())
  name         String           @unique
  description  String?
  isSystemRole Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  tenantId     String?
  tenant       Company?         @relation("TenantRoles", fields: [tenantId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  users        UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  module      String
  action      String
  description String?
  roles       RolePermission[]

  @@unique([module, action])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model OtpToken {
  id         String    @id @default(cuid())
  userId     String
  channel    String
  otpHash    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
}

model Department {
  id                String           @id @default(cuid())
  companyId         String
  name              String
  code              String
  managerEmployeeId String?
  status            String           @default("ACTIVE")
  company           Company          @relation(fields: [companyId], references: [id])
  designations      Designation[]
  employees         Employee[]
  jobRequisitions   JobRequisition[]
  staffingPlans     StaffingPlan[]

  @@unique([companyId, code])
  @@index([companyId, status])
}

model Designation {
  id                String             @id @default(cuid())
  companyId         String
  departmentId      String?
  title             String
  grade             String?
  status            String             @default("ACTIVE")
  department        Department?        @relation(fields: [departmentId], references: [id])
  designationSkills DesignationSkill[]
  employees         Employee[]
  jobRequisitions   JobRequisition[]
  staffingPlans     StaffingPlan[]

  @@index([companyId, status])
  @@index([departmentId])
}

model Location {
  id             String          @id @default(cuid())
  companyId      String
  name           String
  address        String?
  city           String
  state          String
  country        String          @default("India")
  status         String          @default("ACTIVE")
  latitude       Decimal?
  longitude      Decimal?
  employees      Employee[]
  holidays       Holiday[]
  company        Company         @relation(fields: [companyId], references: [id])
  shiftLocations ShiftLocation[]

  @@index([companyId, status])
}

model Employee {
  id                        String                                @id @default(cuid())
  companyId                 String
  employeeCode              String
  firstName                 String
  lastName                  String
  email                     String                                @unique
  phone                     String?
  gender                    String?
  dateOfBirth               DateTime?
  joiningDate               DateTime
  departmentId              String?
  designationId             String?
  locationId                String?
  managerId                 String?
  employmentType            String                                @default("FULL_TIME")
  status                    EmployeeStatus                        @default(ACTIVE)
  probationConfirmedAt      DateTime?
  inviteToken               String?
  resignationDate           DateTime?
  lastWorkingDay            DateTime?
  exitReason                String?
  personalEmail             String?
  createdAt                 DateTime                              @default(now())
  updatedAt                 DateTime                              @updatedAt
  employmentTypeId          String?
  gradeId                   String?
  panNumber                 String?
  providentFundAccount      String?
  uan                       String?
  bloodGroup                String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  maritalStatus             String?
  additionalSalaries        AdditionalSalary[]
  announcementReads         AnnouncementRead[]
  appraisals                Appraisal[]
  attendanceLogs            AttendanceLog[]
  attendanceRegularizations AttendanceRegularization[]
  compOffConversions        CompOffConversion[]
  assets                    CompanyAsset[]
  compensationRevisions     CompensationRevision[]
  customFieldValues         CustomFieldValue[]
  company                   Company                               @relation(fields: [companyId], references: [id])
  department                Department?                           @relation(fields: [departmentId], references: [id])
  designation               Designation?                          @relation(fields: [designationId], references: [id])
  employmentTypeRelation    EmploymentType?                       @relation("EmployeeEmploymentType", fields: [employmentTypeId], references: [id])
  grade                     EmployeeGrade?                        @relation(fields: [gradeId], references: [id])
  location                  Location?                             @relation(fields: [locationId], references: [id])
  addresses                 EmployeeAddress[]
  advances                  EmployeeAdvance[]
  bankDetails               EmployeeBankDetail?
  benefitApplications       EmployeeBenefitApplication[]
  benefitClaims             EmployeeBenefitClaim[]
  documents                 EmployeeDocument[]
  educationHistory          EmployeeEducation[]
  familyDetails             EmployeeFamilyDetail[]
  insurancePolicies         EmployeeInsurance[]
  loans                     EmployeeLoan[]
  promotions                EmployeePromotion[]
  referrals                 EmployeeReferral[]                    @relation("Referrer")
  skillMaps                 EmployeeSkillMap[]
  taxDeclarations           EmployeeTaxExemptionDeclaration?
  taxExemptionProofs        EmployeeTaxExemptionProofSubmission[]
  transfers                 EmployeeTransfer[]
  exitInterviews            ExitInterview?                        @relation("ExitEmployee")
  interviewsConducted       ExitInterview[]                       @relation("ExitInterviewer")
  expenses                  Expense[]
  feedbackRequestsProvider  FeedbackRequest[]                     @relation("FeedbackProvider")
  feedbackRequestsRequestor FeedbackRequest[]                     @relation("FeedbackRequestor")
  fullAndFinalStatements    FullAndFinalStatement?
  gratuities                Gratuity[]
  grievances                Grievance[]
  insuranceClaims           InsuranceClaim[]
  insuranceDependents       InsuranceDependent[]
  submittedFeedbacks        InterviewFeedback[]
  interviewsAssigned        Interviewer[]
  requisitionsApproved      JobRequisition[]                      @relation("RequisitionApprover")
  requisitionsRequested     JobRequisition[]                      @relation("RequisitionRequestor")
  leaveBalances             LeaveBalance[]
  leaveEncashments          LeaveEncashment[]
  leaveLedgerEntries        LeaveLedgerEntry[]
  leavePolicyAssignments    LeavePolicyAssignment[]
  leaveRequests             LeaveRequest[]
  overtimeRequests          OvertimeRequest[]
  payslips                  Payslip[]
  policyAcknowledgments     PolicyAcknowledgment[]
  recognitions              RecognitionReward[]                   @relation("RecognitionRecipient")
  reminderLogs              ReminderLog[]
  retentionBonuses          RetentionBonus[]
  rewardLedgers             RewardLedger[]
  salaryStructures          SalaryStructure[]
  salaryWithholdings        SalaryWithholding[]
  shiftAssignments          ShiftAssignment[]
  shiftRequests             ShiftRequest[]
  signedLetters             SignedLetter[]
  surveyResponses           SurveyResponse[]
  trainingFeedbacks         TrainingFeedback[]
  trainingResults           TrainingResult[]
  travelRequests            TravelRequest[]
  user                      User?
  penaltyLogs               PenaltyLog[]

  @@unique([companyId, employeeCode])
  @@index([companyId, status])
  @@index([departmentId])
  @@index([designationId])
  @@index([locationId])
  @@index([managerId])
}

model EmployeeDocument {
  id                 String    @id @default(cuid())
  employeeId         String
  documentType       String
  fileUrl            String
  verificationStatus String    @default("PENDING")
  verifiedBy         String?
  verifiedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  employee           Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId, verificationStatus])
}

model EmployeeBankDetail {
  id                     String   @id @default(cuid())
  employeeId             String   @unique
  accountHolderName      String
  bankName               String
  accountNumberEncrypted String
  ifsc                   String
  branch                 String?
  verificationStatus     String   @default("PENDING")
  employee               Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeAddress {
  id           String   @id @default(cuid())
  employeeId   String
  type         String   @default("CURRENT")
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String   @default("India")
  pinCode      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, type])
}

model EmployeeEducation {
  id            String   @id @default(cuid())
  employeeId    String
  degree        String
  institution   String
  yearOfPassing Int
  percentage    Decimal?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeFamilyDetail {
  id           String    @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  dateOfBirth  DateTime?
  occupation   String?
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Shift {
  id             String            @id @default(cuid())
  companyId      String
  name           String
  startTime      String
  endTime        String
  graceMinutes   Int               @default(0)
  halfDayMinutes Int               @default(240)
  status         String            @default("ACTIVE")
  logs           AttendanceLog[]
  assignments    ShiftAssignment[]
  locations      ShiftLocation[]
  requests       ShiftRequest[]
}

model AttendanceRule {
  id                   String  @id @default(cuid())
  companyId            String  @unique
  lateMarkAfterMinutes Int     @default(10)
  maxLateMarksPerMonth Int     @default(3)
  geoRequired          Boolean @default(false)
  selfieRequired       Boolean @default(false)
  biometricRequired    Boolean @default(false)
  overtimeEnabled      Boolean @default(true)
  allowedIpsJson       Json?
}

model AttendanceLog {
  id                String                     @id @default(cuid())
  employeeId        String
  shiftId           String?
  date              DateTime
  checkInAt         DateTime?
  checkOutAt        DateTime?
  checkInLatitude   Decimal?
  checkInLongitude  Decimal?
  checkOutLatitude  Decimal?
  checkOutLongitude Decimal?
  source            String                     @default("WEB")
  status            AttendanceStatus           @default(PRESENT)
  approvedBy        String?
  createdAt         DateTime                   @default(now())
  checkInAccuracy   Decimal?
  checkOutAccuracy  Decimal?
  employee          Employee                   @relation(fields: [employeeId], references: [id])
  shift             Shift?                     @relation(fields: [shiftId], references: [id])
  regularizations   AttendanceRegularization[]
  overtimeRequests  OvertimeRequest[]
  anomalies         AttendanceAnomaly[]
  autoClockOut      Boolean                    @default(false)

  @@unique([employeeId, date])
  @@index([date, status])
  @@index([shiftId])
}

model AttendanceRegularization {
  id                  String         @id @default(cuid())
  employeeId          String
  attendanceLogId     String?
  requestedCheckInAt  DateTime?
  requestedCheckOutAt DateTime?
  reason              String
  status              ApprovalStatus @default(PENDING)
  decidedBy           String?
  decidedAt           DateTime?
  createdAt           DateTime       @default(now())
  attendanceLog       AttendanceLog? @relation(fields: [attendanceLogId], references: [id])
  employee            Employee       @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([attendanceLogId])
}

model OvertimeRequest {
  id                String             @id @default(cuid())
  employeeId        String
  attendanceLogId   String
  hours             Decimal
  reason            String
  status            ApprovalStatus     @default(PENDING)
  decidedBy         String?
  decidedAt         DateTime?
  createdAt         DateTime           @default(now())
  compOffConversion CompOffConversion?
  attendanceLog     AttendanceLog      @relation(fields: [attendanceLogId], references: [id])
  employee          Employee           @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([attendanceLogId])
}

model PenaltyLog {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  anomalyType   String   // "LATE" | "EARLY_EXIT" | "ABSENT" | "MISSED_PUNCH" | "OUT_TIME"
  penaltyType   String   // "HALF_DAY" | "FULL_DAY"
  leaveType     String   // "Loss of Pay"
  deductionDays Decimal
  month         Int
  year          Int
  status        String   // "OPEN" | "APPROVED" | "CONVERTED_LOP" | "REVERTED"
  appliedOn     DateTime @default(now())
  revertedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  company       Company  @relation(fields: [companyId], references: [id])
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@index([companyId, month, year])
  @@index([employeeId, status])
}

model LeaveType {
  id                  String                 @id @default(cuid())
  companyId           String
  name                String
  code                String
  annualQuota         Int
  carryForwardAllowed Boolean                @default(false)
  sandwichRuleEnabled Boolean                @default(false)
  compOffLinked       Boolean                @default(false)
  encashable          Boolean                @default(false)
  maxEncashableDays   Int                    @default(0)
  availableDuringNotice Boolean              @default(true)
  status              String                 @default("ACTIVE")
  compOffConversions  CompOffConversion[]
  accrualSchedules    LeaveAccrualSchedule[]
  balances            LeaveBalance[]
  leaveEncashments    LeaveEncashment[]
  ledgerEntries       LeaveLedgerEntry[]
  requests            LeaveRequest[]

  @@unique([companyId, code])
}

model LeaveBalance {
  id             String    @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  year           Int
  openingBalance Decimal   @default(0)
  accrued        Decimal   @default(0)
  used           Decimal   @default(0)
  carriedForward Decimal   @default(0)
  available      Decimal   @default(0)
  employee       Employee  @relation(fields: [employeeId], references: [id])
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id          String         @id @default(cuid())
  employeeId  String
  leaveTypeId String
  fromDate    DateTime
  toDate      DateTime
  days        Decimal
  reason      String
  status      ApprovalStatus @default(PENDING)
  managerId   String?
  decidedAt   DateTime?
  createdAt   DateTime       @default(now())
  employee    Employee       @relation(fields: [employeeId], references: [id])
  leaveType   LeaveType      @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId, status])
  @@index([leaveTypeId])
  @@index([fromDate, toDate])
}

model SalaryStructureTemplate {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  components  Json     // Array of { name, type: "EARNING"|"DEDUCTION", calcType: "FORMULA"|"FIXED"|"SYSTEM", formula?: string, amount?: number }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])

  @@map("salary_structure_templates")
  @@index([companyId, status])
}

model SalaryStructure {
  id              String   @id @default(cuid())
  employeeId      String
  effectiveFrom   DateTime
  annualCtc       Decimal
  basic           Decimal
  hra             Decimal
  allowances      Decimal  @default(0)
  employerPf      Decimal  @default(0)
  employeePf      Decimal  @default(0)
  esi             Decimal  @default(0)
  professionalTax Decimal  @default(0)
  tds             Decimal  @default(0)
  status          String   @default("ACTIVE")
  employee        Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([effectiveFrom])
}

model PayrollRun {
  id          String         @id @default(cuid())
  companyId   String
  month       Int
  year        Int
  status      ApprovalStatus @default(DRAFT)
  processedBy String?
  processedAt DateTime?
  lockedAt    DateTime?
  company     Company        @relation(fields: [companyId], references: [id])
  payslips    Payslip[]

  @@unique([companyId, month, year])
  @@index([companyId, status])
}

model Payslip {
  id             String              @id @default(cuid())
  payrollRunId   String
  employeeId     String
  grossPay       Decimal
  deductions     Decimal
  netPay         Decimal
  fileUrl        String?
  status         ApprovalStatus      @default(DRAFT)
  loanRepayments LoanRepayment[]
  components     PayrollComponent[]
  corrections    PayrollCorrection[]
  employee       Employee            @relation(fields: [employeeId], references: [id])
  payrollRun     PayrollRun          @relation(fields: [payrollRunId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([employeeId, status])
}

model PayrollComponent {
  id        String  @id @default(cuid())
  payslipId String
  type      String
  name      String
  amount    Decimal
  payslip   Payslip @relation(fields: [payslipId], references: [id])
}

model PayrollComponentConfig {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  category           String   // "BASE" | "RECURRING" | "VARIABLE" | "ADHOC"
  kind               String   // "ALLOWANCE" | "REIMBURSEMENT" | "DEDUCTION"
  taxable            Boolean
  annualLimit        Int?
  individualOverride Boolean
  proofRequired      Boolean
  esiApplicable      Boolean
  includedInCtc      Boolean
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company            Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("payroll_component_configs")
}

model Holiday {
  id         String    @id @default(cuid())
  companyId  String
  locationId String?
  name       String
  date       DateTime
  type       String
  status     String    @default("ACTIVE")
  company    Company   @relation(fields: [companyId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([companyId, status])
  @@index([date])
}

model Expense {
  id                String         @id @default(cuid())
  employeeId        String
  category          String
  amount            Decimal
  receiptUrl        String?
  claimDate         DateTime
  status            ApprovalStatus @default(PENDING)
  managerApprovedBy String?
  hrApprovedBy      String?
  reimbursedAt      DateTime?
  employee          Employee       @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([claimDate])
}

model EmployeeInsurance {
  id             String               @id @default(cuid())
  employeeId     String
  provider       String
  policyNumber   String
  policyType     String
  coverageAmount Decimal
  premiumAmount  Decimal              @default(0)
  startDate      DateTime
  endDate        DateTime
  status         String               @default("ACTIVE")
  createdAt      DateTime             @default(now())
  employee       Employee             @relation(fields: [employeeId], references: [id])
  claims         InsuranceClaim[]
  dependents     InsuranceDependent[]

  @@index([employeeId, status])
}

model InsuranceDependent {
  id           String             @id @default(cuid())
  employeeId   String
  insuranceId  String?
  fullName     String
  relationship String
  dateOfBirth  DateTime?
  status       String             @default("ACTIVE")
  createdAt    DateTime           @default(now())
  employee     Employee           @relation(fields: [employeeId], references: [id])
  insurance    EmployeeInsurance? @relation(fields: [insuranceId], references: [id])

  @@index([employeeId, status])
  @@index([insuranceId])
}

model InsuranceClaim {
  id          String            @id @default(cuid())
  employeeId  String
  insuranceId String
  claimNumber String?
  claimType   String
  claimAmount Decimal
  claimDate   DateTime
  documentUrl String?
  status      ApprovalStatus    @default(PENDING)
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime          @default(now())
  employee    Employee          @relation(fields: [employeeId], references: [id])
  insurance   EmployeeInsurance @relation(fields: [insuranceId], references: [id])

  @@index([employeeId, status])
  @@index([insuranceId])
  @@index([claimDate])
}

model JobRequisition {
  id            String       @id @default(cuid())
  companyId     String
  departmentId  String
  title         String
  openings      Int          @default(1)
  status        String       @default("PENDING")
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  reason        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  designationId String?
  jobPostings   JobPosting[]
  approvedBy    Employee?    @relation("RequisitionApprover", fields: [approvedById], references: [id])
  company       Company      @relation(fields: [companyId], references: [id])
  department    Department   @relation(fields: [departmentId], references: [id])
  designation   Designation? @relation(fields: [designationId], references: [id])
  requestedBy   Employee     @relation("RequisitionRequestor", fields: [requestedById], references: [id])

  @@index([companyId])
  @@index([departmentId])
  @@index([designationId])
}

model JobPosting {
  id            String             @id @default(cuid())
  companyId     String
  title         String
  departmentId  String?
  locationId    String?
  openings      Int                @default(1)
  status        String             @default("OPEN")
  createdBy     String?
  createdAt     DateTime           @default(now())
  requisitionId String?
  referrals     EmployeeReferral[]
  applications  JobApplication[]
  requisition   JobRequisition?    @relation(fields: [requisitionId], references: [id])

  @@index([companyId, status])
  @@index([departmentId])
  @@index([locationId])
}

model Candidate {
  id           String           @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  resumeUrl    String?
  source       String?
  currentStage String           @default("SCREENING")
  createdAt    DateTime         @default(now())
  applications JobApplication[]

  @@index([currentStage])
}

model JobApplication {
  id                  String           @id @default(cuid())
  jobPostingId        String
  candidateId         String
  stage               String           @default("SCREENING")
  status              String           @default("ACTIVE")
  assignedRecruiterId String?
  createdAt           DateTime         @default(now())
  interviews          Interview[]
  interviewRounds     InterviewRound[]
  candidate           Candidate        @relation(fields: [candidateId], references: [id])
  jobPosting          JobPosting       @relation(fields: [jobPostingId], references: [id])
  jobOffers           JobOffer[]

  @@index([jobPostingId, status])
  @@index([candidateId])
  @@index([stage])
}

model InterviewRound {
  id            String         @id @default(cuid())
  applicationId String
  name          String
  roundNumber   Int            @default(1)
  status        String         @default("PENDING")
  createdAt     DateTime       @default(now())
  interviews    Interview[]
