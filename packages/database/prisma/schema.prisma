}

model EmployeeLoan {
  id             String          @id @default(cuid())
  employeeId     String
  principal      Decimal
  interestRate   Decimal         @default(0)
  totalPayable   Decimal
  emiAmount      Decimal
  balanceAmount  Decimal
  status         ApprovalStatus  @default(PENDING)
  repaymentStart DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  employee       Employee        @relation(fields: [employeeId], references: [id])
  repayments     LoanRepayment[]
}

model LoanRepayment {
  id          String       @id @default(cuid())
  loanId      String
  payslipId   String?
  amountPaid  Decimal
  paymentDate DateTime     @default(now())
  createdAt   DateTime     @default(now())
  loan        EmployeeLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payslip     Payslip?     @relation(fields: [payslipId], references: [id])
}

model StaffingPlan {
  id                String      @id @default(cuid())
  companyId         String
  departmentId      String
  designationId     String
  budgetedHeadcount Int
  currentHeadcount  Int         @default(0)
  startDate         DateTime
  endDate           DateTime
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  department        Department  @relation(fields: [departmentId], references: [id])
  designation       Designation @relation(fields: [designationId], references: [id])

  @@unique([companyId, departmentId, designationId])
}

model EmployeeReferral {
  id                 String         @id @default(cuid())
  referrerId         String
  candidateName      String
  candidateEmail     String
  candidatePhone     String?
  jobPostingId       String
  bonusAmount        Decimal        @default(0)
  status             ApprovalStatus @default(PENDING)
  additionalSalaryId String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  jobPosting         JobPosting     @relation(fields: [jobPostingId], references: [id])
  referrer           Employee       @relation("Referrer", fields: [referrerId], references: [id])
}

model Grievance {
  id           String         @id @default(cuid())
  employeeId   String
  title        String
  description  String
  category     String
  anonymous    Boolean        @default(false)
  status       ApprovalStatus @default(PENDING)
  assignedToId String?
  resolution   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  employee     Employee       @relation(fields: [employeeId], references: [id])
}

model FeedbackRequest {
  id          String   @id @default(cuid())
  appraisalId String?
  requestorId String
  providerId  String
  status      String   @default("PENDING")
  questions   Json
  answers     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  provider    Employee @relation("FeedbackProvider", fields: [providerId], references: [id])
  requestor   Employee @relation("FeedbackRequestor", fields: [requestorId], references: [id])
}

model AppraisalCycle {
  id         String      @id @default(cuid())
  companyId  String
  name       String
  startDate  DateTime
  endDate    DateTime
  status     String      @default("DRAFT")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  appraisals Appraisal[]
  company    Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model AppraisalTemplate {
  id         String         @id @default(cuid())
  companyId  String
  name       String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  appraisals Appraisal[]
  kras       AppraisalKra[]
  company    Company        @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model AppraisalKra {
  id               String            @id @default(cuid())
  templateId       String
  title            String
  weightagePercent Decimal
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  goals            AppraisalGoal[]
  template         AppraisalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Appraisal {
  id           String            @id @default(cuid())
  companyId    String
  cycleId      String
  employeeId   String
  templateId   String
  status       String            @default("PENDING")
  selfScore    Decimal?
  managerScore Decimal?
  finalScore   Decimal?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  company      Company           @relation(fields: [companyId], references: [id])
  cycle        AppraisalCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee     Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template     AppraisalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  goals        AppraisalGoal[]

  @@index([companyId])
  @@index([cycleId])
  @@index([employeeId])
  @@index([templateId])
}

model AppraisalGoal {
  id            String       @id @default(cuid())
  appraisalId   String
  kraId         String
  description   String
  selfRating    Decimal?
  managerRating Decimal?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  appraisal     Appraisal    @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  kra           AppraisalKra @relation(fields: [kraId], references: [id], onDelete: Cascade)

  @@index([appraisalId])
  @@index([kraId])
}

model RetentionBonus {
  id                 String         @id @default(cuid())
  companyId          String
  employeeId         String
  bonusAmount        Decimal
  bonusDate          DateTime
  reason             String?
  status             ApprovalStatus @default(PENDING)
  additionalSalaryId String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  company            Company        @relation(fields: [companyId], references: [id])
  employee           Employee       @relation(fields: [employeeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
}

model SalaryWithholding {
  id         String    @id @default(cuid())
  companyId  String
  employeeId String
  fromDate   DateTime
  toDate     DateTime?
  reason     String?
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
}

model CompanyPolicy {
  id                     String                 @id @default(cuid())
  companyId              String
  title                  String
  category               String
  description            String?
  fileUrl                String?
  contentHtml            String?
  version                String                 @default("1.0")
  effectiveDate          DateTime               @default(now())
  requiresAcknowledgment Boolean                @default(true)
  status                 String                 @default("ACTIVE")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  company                Company                @relation(fields: [companyId], references: [id])
  acknowledgments        PolicyAcknowledgment[]

  @@index([companyId, status])
}

model PolicyAcknowledgment {
  id             String        @id @default(cuid())
  policyId       String
  employeeId     String
  acknowledgedAt DateTime      @default(now())
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy         CompanyPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, employeeId])
}

model Announcement {
  id          String             @id @default(cuid())
  companyId   String
  title       String
  body        String
  pinned      Boolean            @default(false)
  audience    String             @default("ALL")
  publishedAt DateTime           @default(now())
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id])
  reads       AnnouncementRead[]

  @@index([companyId, publishedAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  employeeId     String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([announcementId, employeeId])
}

model CustomFieldDefinition {
  id          String             @id @default(cuid())
  companyId   String
  entityType  String             @default("EMPLOYEE")
  label       String
  fieldKey    String
  fieldType   String
  optionsJson String?
  required    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id])
  values      CustomFieldValue[]

  @@unique([companyId, fieldKey])
}

model CustomFieldValue {
  id           String                @id @default(cuid())
  definitionId String
  employeeId   String
  valueJson    String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  employee     Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([definitionId, employeeId])
}

model Survey {
  id        String           @id @default(cuid())
  companyId String
  title     String
  type      String
  status    String           @default("DRAFT")
  anonymous Boolean          @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id])
  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([companyId, status])
}

model SurveyQuestion {
  id          String @id @default(cuid())
  surveyId    String
  text        String
  kind        String
  optionsJson Json?
  order       Int
  survey      Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model SurveyResponse {
  id          String    @id @default(cuid())
  surveyId    String
  employeeId  String?
  answersJson Json
  submittedAt DateTime  @default(now())
  employee    Employee? @relation(fields: [employeeId], references: [id])
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, employeeId])
}

model ReminderRule {
  id              String        @id @default(cuid())
  companyId       String
  event           String
  daysOffset      Int           @default(0)
  channel         String
  enabled         Boolean       @default(true)
  templateSubject String
  templateBody    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  logs            ReminderLog[]
  company         Company       @relation(fields: [companyId], references: [id])

  @@unique([companyId, event, daysOffset])
}

model ReminderLog {
  id          String       @id @default(cuid())
  ruleId      String
  employeeId  String
  sentAt      DateTime     @default(now())
  payloadJson Json?
  employee    Employee     @relation(fields: [employeeId], references: [id])
  rule        ReminderRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, employeeId, sentAt])
}

model CompensationCycle {
  id            String                 @id @default(cuid())
  companyId     String
  name          String
  status        String                 @default("DRAFT")
  effectiveDate DateTime
  guidelineJson Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  company       Company                @relation(fields: [companyId], references: [id])
  revisions     CompensationRevision[]

  @@index([companyId, status])
}

model CompensationRevision {
  id              String            @id @default(cuid())
  cycleId         String
  employeeId      String
  currentCtc      Decimal
  appraisalScore  Decimal?
  proposedPercent Decimal?
  approvedPercent Decimal?
  newCtc          Decimal?
  status          String            @default("DRAFT")
  cycle           CompensationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee        Employee          @relation(fields: [employeeId], references: [id])

  @@unique([cycleId, employeeId])
}

model SignedLetter {
  id                String   @id @default(cuid())
  generatedLetterId String
  employeeId        String
  signedAt          DateTime @default(now())
  signatureName     String
  employee          Employee @relation(fields: [employeeId], references: [id])
}

model CompanyAsset {
  id           String    @id @default(cuid())
  companyId    String
  assetTag     String    @unique
  type         String
  item         String
  assignedToId String?
  status       String    @default("AVAILABLE")
  condition    String    @default("GOOD")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedTo   Employee? @relation(fields: [assignedToId], references: [id])
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  EXITED
  PRE_ONBOARDING
  PROBATION
  NOTICE_PERIOD
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  HOLD
  PAID
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  HOLIDAY
  WEEK_OFF
  AUTO_CLOCK_OUT
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  PUSH
  IN_APP
}

enum LeaveLedgerEntryType {
  ACCRUAL
  DEBIT
  CREDIT
  ENCASHMENT
}

enum AnomalyType {
  LATE
  EARLY_EXIT
  SHORT_HOURS
  MISSED_PUNCH
  ABSENT
}

enum AnomalyStatus {
  OPEN
  APPROVED
  CONVERTED_TO_LOP
  OVERRIDDEN
}

model AttendanceAnomaly {
  id              String        @id @default(cuid())
  attendanceLogId String
  employeeId      String
  type            AnomalyType
  shiftId         String?
  expectedTime    String?
  actualTime      String?
  diffMinutes     Int           @default(0)
  status          AnomalyStatus @default(OPEN)
  decidedBy       String?
  decidedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attendanceLog   AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([attendanceLogId])
}
